<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --black:#000000;
  --white:#FFFFFF;
  --off:#F5F5F3;
  --gray:#E8E8E6;
  --gray2:#BDBDBA;
  --muted:#767672;
  --red:#D42B2B;
  --z-nav:300;
  --z-modal:250;
  --z-elevated:10;
  --z-base:1;
}
html{scroll-behavior:smooth}
body{font-family:'Barlow',sans-serif;background:var(--white);color:var(--black);font-size:16px;overflow-x:hidden;line-height:1.4}
a{text-decoration:none;color:inherit}

/* ── SKIP LINK ── */
.skip-link{
  position:absolute;top:-40px;left:0;
  background:var(--red);color:var(--white);
  padding:8px 16px;z-index:var(--z-nav);
  text-decoration:underline;font-size:12px;
}
.skip-link:focus{top:0}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:var(--z-nav);
  padding:0 56px;height:60px;
  background:var(--black);
  border-bottom:1px solid #1a1a1a;
  display:flex;align-items:center;justify-content:space-between;
}
.nav-logo{
  font-family:'Bebas Neue',sans-serif;
  font-size:22px;letter-spacing:4px;
  color:var(--white);
}
.nav-back{
  display:flex;align-items:center;gap:8px;
  font-size:11px;font-weight:700;letter-spacing:2px;
  text-transform:uppercase;color:var(--muted);
  transition:color .2s;
}
.nav-back:hover{color:var(--white)}
.nav-back:focus{outline:2px solid var(--red)}
.nav-back svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2.5;stroke-linecap:round;stroke-linejoin:round}
.nav-right{display:flex;align-items:center;gap:12px}
.nav-pkg{
  background:var(--red);color:var(--white);
  font-size:11px;font-weight:700;letter-spacing:2px;
  text-transform:uppercase;padding:8px 18px;
  transition:background .2s;cursor:pointer;
}
.nav-pkg:hover{background:#b01f1f}
.nav-pkg:focus{outline:2px solid var(--white)}
.nav-wa{
  display:inline-flex;align-items:center;gap:6px;
  background:#25D366;color:var(--white);
  font-size:11px;font-weight:700;letter-spacing:1.5px;
  text-transform:uppercase;padding:8px 16px;
  transition:background .2s;cursor:pointer;
}
.nav-wa:hover{background:#1ebd5a}
.nav-wa:focus{outline:2px solid var(--white)}
.nav-wa svg{width:13px;height:13px;fill:var(--white)}

/* ── HERO ── */
.page-hero{
  padding-top:60px;
  background:var(--black);
  padding-bottom:0;
  overflow:hidden;
}
.hero-inner{
  padding:72px 56px 64px;
  max-width:1440px;margin:0 auto;
  display:grid;grid-template-columns:1fr 1fr;
  gap:80px;align-items:end;
}
.hero-eyebrow{
  font-size:11px;font-weight:700;letter-spacing:4px;
  text-transform:uppercase;color:var(--red);
  margin-bottom:20px;display:block;
}
.hero-h1{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(64px,9vw,128px);
  color:var(--white);line-height:.9;
  letter-spacing:2px;margin-bottom:28px;
}
.hero-h1 em{color:var(--red);font-style:normal}
.hero-desc{
  font-size:16px;font-weight:300;
  color:rgba(255,255,255,.75);
  line-height:1.8;max-width:480px;
}
.hero-stats{
  display:grid;grid-template-columns:1fr 1fr;
  gap:1px;background:rgba(255,255,255,.1);
  border:1px solid rgba(255,255,255,.1);
  align-self:end;
}
.hs-cell{
  background:var(--black);
  padding:36px 32px;text-align:center;
}
.hs-num{
  font-family:'Bebas Neue',sans-serif;
  font-size:56px;color:var(--white);
  line-height:1;letter-spacing:1px;
  display:block;margin-bottom:6px;
}
.hs-num em{color:var(--red);font-style:normal}
.hs-lbl{
  font-size:10px;font-weight:700;
  letter-spacing:2.5px;text-transform:uppercase;
  color:rgba(255,255,255,.35);
}

/* ── FILTER BAR ── */
.filter-bar{
  background:var(--off);
  border-bottom:1px solid var(--gray);
  padding:0 56px;
  display:flex;align-items:center;gap:0;
  overflow-x:auto;
}
.filter-btn{
  font-size:11px;font-weight:700;letter-spacing:2px;
  text-transform:uppercase;color:var(--muted);
  padding:18px 24px;
  border-bottom:2px solid transparent;
  cursor:pointer;transition:all .2s;
  white-space:nowrap;background:none;border-top:none;
  border-left:none;border-right:none;
}
.filter-btn:hover{color:var(--black)}
.filter-btn:focus{outline:2px solid var(--red);outline-offset:-2px}
.filter-btn.active{color:var(--red);border-bottom-color:var(--red)}

/* ── CASE STUDIES GRID ── */
.studies-section{padding:80px 56px;background:var(--white)}
.studies-grid{max-width:1440px;margin:0 auto;display:flex;flex-direction:column;gap:0}

/* ── CASE STUDY CARD ── */
.cs-card{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:0;
  border-bottom:1px solid var(--gray);
  transition:background .25s;
}
.cs-card:first-child{border-top:1px solid var(--gray)}
.cs-card:hover{background:var(--off)}
.cs-card.reverse{direction:rtl}
.cs-card.reverse > *{direction:ltr}
.cs-card.hidden{display:none}

/* Visual side */
.cs-visual{
  position:relative;
  min-height:480px;
  overflow:hidden;
  display:flex;align-items:center;justify-content:center;
}
.cs-bg{
  position:absolute;inset:0;
  display:flex;align-items:center;justify-content:center;
}
.cs-bg-word{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(80px,12vw,180px);
  font-weight:900;letter-spacing:4px;
  color:rgba(255,255,255,.06);
  pointer-events:none;user-select:none;
  position:relative;z-index:var(--z-base);
}
.cs-metrics{
  position:absolute;bottom:32px;left:32px;right:32px;
  display:flex;gap:8px;flex-wrap:wrap;
  z-index:var(--z-elevated);
}
.cs-metric{
  background:rgba(0,0,0,.55);
  backdrop-filter:blur(8px);
  border:1px solid rgba(255,255,255,.12);
  padding:10px 18px;
  text-align:center;
}
.cs-metric-num{
  font-family:'Bebas Neue',sans-serif;
  font-size:28px;color:var(--white);
  line-height:1;display:block;
  letter-spacing:1px;
}
.cs-metric-num em{color:var(--red);font-style:normal}
.cs-metric-lbl{
  font-size:9px;font-weight:700;
  letter-spacing:2px;text-transform:uppercase;
  color:rgba(255,255,255,.45);
  display:block;margin-top:3px;
}

/* Content side */
.cs-content{
  padding:56px 52px;
  display:flex;flex-direction:column;
  justify-content:center;
  border-left:1px solid var(--gray);
}
.cs-card.reverse .cs-content{border-left:none;border-right:1px solid var(--gray)}
.cs-tag{
  font-size:10px;font-weight:700;letter-spacing:2.5px;
  text-transform:uppercase;color:var(--red);
  margin-bottom:12px;display:block;
}
.cs-client{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(36px,5vw,64px);
  letter-spacing:1px;line-height:.95;
  margin-bottom:6px;color:var(--black);
}
.cs-project{
  font-size:14px;font-weight:300;color:var(--muted);
  margin-bottom:32px;letter-spacing:.5px;
}
.cs-divider{
  width:40px;height:3px;background:var(--red);
  margin-bottom:28px;
}

/* Story blocks */
.cs-story{display:flex;flex-direction:column;gap:24px;margin-bottom:36px}
.story-block{}
.story-label{
  font-size:10px;font-weight:700;letter-spacing:2px;
  text-transform:uppercase;color:var(--gray2);
  margin-bottom:8px;display:block;
}
.story-text{
  font-size:14px;font-weight:300;color:var(--muted);
  line-height:1.8;
}

/* Results list */
.cs-results{list-style:none;margin-bottom:36px}
.cs-results li{
  display:flex;align-items:flex-start;gap:12px;
  font-size:13px;color:var(--muted);
  padding:8px 0;border-bottom:1px solid var(--gray);
  line-height:1.6;font-weight:300;
}
.cs-results li:last-child{border-bottom:none}
.cs-results li::before{
  content:'↑';color:var(--red);
  font-size:11px;flex-shrink:0;
  margin-top:3px;font-weight:700;
}
.cs-results li strong{color:var(--black);font-weight:600}

/* Tags row */
.cs-tags{display:flex;flex-wrap:wrap;gap:6px}
.cs-tag-pill{
  font-size:9px;font-weight:700;letter-spacing:1.5px;
  text-transform:uppercase;
  border:1px solid var(--gray);
  padding:4px 12px;color:var(--muted);
}

/* ── TESTIMONIALS ── */
.testi-section{
  padding:100px 56px;
  background:var(--black);
}
.testi-inner{max-width:1440px;margin:0 auto}
.testi-header{
  display:flex;justify-content:space-between;
  align-items:baseline;
  border-bottom:1px solid rgba(255,255,255,.1);
  padding-bottom:20px;margin-bottom:56px;
}
.testi-eyebrow{
  font-size:10px;font-weight:700;letter-spacing:3px;
  text-transform:uppercase;color:var(--red);
}
.testi-count{
  font-size:10px;font-weight:600;letter-spacing:2px;
  text-transform:uppercase;color:rgba(255,255,255,.3);
}
.testi-grid{
  display:grid;grid-template-columns:repeat(4,1fr);
  gap:0;border:1px solid rgba(255,255,255,.08);
}
.testi-card{
  padding:44px 36px;
  border-right:1px solid rgba(255,255,255,.08);
  background:var(--black);
}
.testi-card:last-child{border-right:none}
.testi-stars{
  font-size:14px;color:var(--red);
  margin-bottom:20px;letter-spacing:3px;
}
.testi-quote{
  font-size:15px;font-weight:300;
  color:rgba(255,255,255,.75);
  line-height:1.8;margin-bottom:28px;
  font-style:italic;
}
.testi-author{
  display:flex;flex-direction:column;gap:3px;
  border-top:1px solid rgba(255,255,255,.08);
  padding-top:20px;
}
.testi-name{
  font-family:'Bebas Neue',sans-serif;
  font-size:20px;color:var(--white);letter-spacing:1px;
}
.testi-title{
  font-size:11px;font-weight:600;letter-spacing:1.5px;
  text-transform:uppercase;color:rgba(255,255,255,.3);
}

/* ── CTA ── */
.cta-section{
  background:var(--red);padding:80px 56px;
  display:grid;grid-template-columns:1fr auto;
  align-items:center;gap:60px;
  position:relative;overflow:hidden;
}
.cta-section::before{
  content:'RESULTS';position:absolute;
  right:-40px;top:50%;transform:translateY(-50%);
  font-family:'Bebas Neue',sans-serif;
  font-size:200px;font-weight:900;
  color:rgba(0,0,0,.1);letter-spacing:-0.04em;
  pointer-events:none;white-space:nowrap;
}
.cta-h{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(44px,6vw,80px);font-weight:900;
  text-transform:uppercase;letter-spacing:2px;
  color:var(--white);line-height:.9;
  position:relative;z-index:var(--z-base);
}
.cta-h em{
  font-style:normal;color:transparent;
  -webkit-text-stroke:2px rgba(255,255,255,.5);
  display:block;
}
.cta-btns{
  display:flex;flex-direction:column;
  gap:12px;position:relative;z-index:var(--z-base);flex-shrink:0;
}
.btn-white{
  display:block;text-align:center;
  background:var(--white);color:var(--black);
  font-size:11px;font-weight:700;letter-spacing:2px;
  text-transform:uppercase;padding:16px 32px;
  transition:background .2s;white-space:nowrap;cursor:pointer;
}
.btn-white:hover{background:#e8e8e8}
.btn-white:focus{outline:2px solid var(--black)}
.btn-wa-cta{
  display:flex;align-items:center;justify-content:center;
  gap:8px;background:#25D366;color:var(--white);
  font-size:11px;font-weight:700;letter-spacing:2px;
  text-transform:uppercase;padding:16px 32px;
  transition:background .2s;white-space:nowrap;cursor:pointer;
}
.btn-wa-cta:hover{background:#1ebd5a}
.btn-wa-cta:focus{outline:2px solid var(--white)}
.btn-wa-cta svg{width:16px;height:16px;fill:var(--white)}

/* ── FOOTER ── */
footer{
  background:var(--black);padding:28px 56px;
  display:flex;justify-content:space-between;
  align-items:center;border-top:1px solid #1a1a1a;
}
.ft-logo{
  font-family:'Bebas Neue',sans-serif;
  font-size:22px;letter-spacing:4px;color:var(--white);
}
.ft-tag{
  font-size:11px;font-weight:700;letter-spacing:2px;
  text-transform:uppercase;color:var(--muted);
}
.ft-copy{font-size:10px;letter-spacing:1px;color:#333;text-transform:uppercase}

/* ── ANIMATIONS ── */
.reveal{opacity:0;transform:translateY(36px);transition:opacity .75s ease,transform .75s ease}
.reveal.in{opacity:1;transform:translateY(0)}
.d1{transition-delay:.1s}.d2{transition-delay:.2s}.d3{transition-delay:.3s}

/* ── RESPONSIVE ── */
@media(max-width:1200px){
  .testi-grid{grid-template-columns:repeat(2,1fr)}
}

@media(max-width:960px){
  nav,footer,.page-hero,.filter-bar,.studies-section,.testi-section,.cta-section{padding-left:24px;padding-right:24px}
  .hero-inner{grid-template-columns:1fr;gap:40px;padding:52px 24px 48px}
  .cs-card,.cs-card.reverse{grid-template-columns:1fr;direction:ltr}
  .cs-content{border-left:none;border-right:none;border-top:1px solid var(--gray);padding:36px 28px}
  .cs-card.reverse .cs-content{border-right:none;border-top:1px solid var(--gray)}
  .cs-visual{min-height:280px}
  .testi-grid{grid-template-columns:1fr}
  .testi-card{border-right:none;border-bottom:1px solid rgba(255,255,255,.08)}
  .cta-section{grid-template-columns:1fr;gap:32px}
  .cta-section::before{font-size:120px;right:-30px}
  .cta-btns{flex-direction:row;flex-wrap:wrap}
  footer{flex-direction:column;gap:12px;text-align:center}
}

@media(max-width:640px){
  nav{padding:0 16px}
  .hero-inner{padding:40px 16px 32px}
  .filter-bar{padding:0 16px}
  .studies-section{padding:40px 16px}
  .cs-metrics{bottom:16px;left:16px;right:16px}
  .cs-content{padding:32px 20px}
  .testi-section{padding:60px 16px}
  .cta-section{padding:40px 16px}
  .cta-h{font-size:clamp(32px,6vw,44px)}
}
</style>
